{
  "name": "mcpster",
  "version": "0.2.7",
  "description": "Agnostic TypeScript SDK for building MCP servers",
  "license": "MIT",
  "author": "ruco",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sdk",
    "typescript",
    "llm",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ruco-ai/mcpster"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "mcpster-deploy": "./dist/deploy/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
